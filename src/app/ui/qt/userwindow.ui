   <property name="styleSheet">
    <string notr="true">QWidget{
	color: #F8F8F2;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
#bgApp {	
	background-color: rgb(44, 49, 58);
	border-radius: 10px;
}
#ContentBox {border-radius: 10px;}
#contentTopBg {
	background-color: rgb(33, 37, 43);
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
}
#bottomBar {
	background-color: rgb(33, 37, 43);
	border-bottom-left-radius: 10px;
	border-bottom-right-radius: 10px;
}
#topLogo {
	background-image: url(:/imagem/images/saturn_logo.png);
	background-position: center;
	background-repeat: no-repeat;
}

#titleRightInfo {padding-left: 10px;}
#detailsTitle {font: 10pt; color: #8BE9FD;}
#contactTitle {font: 10pt; color: #8BE9FD;}
#addressTitle {font: 10pt; color: #8BE9FD;}
#bgContact {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
#bgAddress {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
#bgUser {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
#closeAppBtn{ background-color: rgba(255, 255, 255, 0); border: none;}
#closeAppBtn:hover{ background-color:#ff5555;}
#closeAppBtn:pressed { background-color:rgb(193, 64, 64); border-style: solid;}
#btn_loguser {
	border-radius: 5px;	
	border: none;
	background-color: rgb(66, 209, 102);
}
#btn_loguser:hover {
	background-color: #50fA7B;
}
#btn_loguser:pressed {
	background-color: rgb(66, 209, 102);
}
#btn_cancel {
	border-radius: 5px;	
	border: none;
	background-color: rgb(52, 59, 72);
}
#btn_cancel:hover {
	background-color: rgb(61, 70, 86);
}
#btn_cancel:pressed {
	background-color: rgb(52, 59, 72);
}

/*LineEdit */
#content .QLineEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QLineEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QLineEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*TextEdit */
#content .QTextEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QTextEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QTextEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*QLabel */
#content .QLabel {
	color: #EAEAF0;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
</string>
