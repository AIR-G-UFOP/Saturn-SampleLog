   <property name="styleSheet">
    <string notr="true">QWidget{
	color:#f8f8f2;
	font: 10pt &quot;AbrilTitlingNarrowW04-Bold&quot;;
}
/* Tooltip */
QToolTip {
	color: #ffffff;
	background-color: rgba(33, 37, 43, 180);
	border: 1px solid rgb(44, 49, 58);
	background-image: none;
	background-position: left center;
	background-repeat: no-repeat;
	border: none;
	border-left: 2px solid #ff5555;
	text-align: left;
	padding-left: 8px;
	margin: 0px;
}
/* Bg App */
#bgApp {	
	background-color: rgb(40, 44, 52);
	border: 1px solid rgb(44, 49, 58);
	border-radius: 5px;	
}
#topLogo {
	background-color: rgb(33, 37, 43);
	background-image: url(:/imagem/images/saturn_logo2.png);
	background-position: centered;
	background-repeat: no-repeat;
}
#titleRightInfo { 
	padding-left: 10px;
	font: 10pt &quot;AbrilTitlingNarrowW04-Bold&quot;;
 }
/* Content App */
#contentTopBg{	
	background-color: rgb(33, 37, 43);
}
#contentBottom{
	border-top: 3px solid rgb(44, 49, 58);
}
/* Top Buttons */
#rightButtons .QPushButton { background-color: rgba(255, 255, 255, 0); border: none;  border-radius: 5px; }
#rightButtons .QPushButton:hover { background-color: rgb(44, 49, 57); border-style: solid; border-radius: 4px; }
#rightButtons .QPushButton:pressed { background-color: rgb(23, 26, 30); border-style: solid; border-radius: 4px; }
#closeAppBtn{ background-color: rgba(255, 255, 255, 0); border: none; border-radius: 5px;}
#closeAppBtn:hover{ background-color:#ff5555;}
#closeAppBtn:pressed { background-color:rgb(193, 64, 64); border-style: solid; border-radius: 5px;}
/* Bottom Bar */
#bottomBar { background-color: rgb(44, 49, 58); }
#bottomBar QLabel { font-size: 10px; color: rgb(113, 126, 149);}
#bottomBar .QProgressBar {
	border-radius: 5px;
	background-color: rgb(52, 59, 72);
	text-align: center;
	color:  rgb(33, 37, 43);
	font-size: 9px;
}
#bottomBar .QProgressBar::chunk {
    background-color: #50FA7B;      
    border-radius: 5px;
}
/*Button */
#btn_loguser {
	border-radius: 5px;	
	background-color:#50FA7B;
	color: rgb(33, 37, 43);
}
#btn_loguser:hover {
	border: 2px solid rgb(61, 70, 86);
}
#btn_loguser:pressed {
	border: 2px solid #50FA7B;
}
QPushButton {
	border-radius: 5px;	
	background-color: rgb(52, 59, 72);
	color: #F8F8F2;
}
QPushButton:hover {
	border: 2px solid rgb(61, 70, 86);
}
QPushButton:pressed {
	border: 2px solid  rgb(52, 59, 72);
}

/*LineEdit */
#content .QLineEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QLineEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QLineEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*TextEdit */
#content .QTextEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QTextEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QTextEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*QLabel */
#content .QLabel {
	color: #F8F8F2
}
/*RadioButton */
QRadioButton::indicator {
    border: 3px solid rgb(52, 59, 72);
	width: 15px;
	height: 15px;
	border-radius: 10px;
    background: rgb(44, 49, 60);
	color: #F8F8F2;
}
QRadioButton::indicator:hover {
    border: 3px solid rgb(58, 66, 81);
}
QRadioButton::indicator:checked {
    background: 3px solid rgb(94, 106, 130);
	border: 3px solid rgb(52, 59, 72);	
}
/*ComboBox */
QComboBox{
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	border: 2px solid rgb(52, 59, 72);
	padding: 5px;
	padding-left: 10px;
}
QComboBox:hover{
	border: 2px solid rgb(64, 71, 88);
}
QComboBox::drop-down {
	subcontrol-origin: padding;
	subcontrol-position: top right;
	width: 25px; 
	border-left-width: 3px;
	border-left-color: rgba(39, 44, 54, 150);
	border-left-style: solid;
	border-top-right-radius: 3px;
	border-bottom-right-radius: 3px;	
	background-image: url(:/icons/icons/cil-arrow-drop-down.png);
	background-position: center;
	background-repeat: no-reperat;
 }
QComboBox QAbstractItemView {
	/*color: rgb(255, 121, 198);*/
	color: #ff5555;	
	background-color: rgb(33, 37, 43);
	padding: 10px;
	selection-background-color: rgb(39, 44, 54);
}
</string>
