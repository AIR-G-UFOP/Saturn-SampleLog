  <property name="styleSheet">
   <string notr="true">QWidget{
	color: #F8F8F2;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
#bgApp {	
	background-color: rgb(44, 49, 58);
	border-radius: 10px;
}
#ContentBox {border-radius: 10px;}
#contentTopBg {
	background-color: #20232f;
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
}
#bottomBar {
	background-color: rgb(33, 37, 43);
	border-bottom-left-radius: 10px;
	border-bottom-right-radius: 10px;
}
#bgUser {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}

#btn_saveuser {
	border-radius: 5px;	
	border: none;
	background-color: rgb(66, 209, 102);
}
#btn_saveuser:hover {
	background-color: #50fA7B;
}
#btn_saveuser:pressed {
	background-color: rgb(66, 209, 102);
}
#btn_cancel {
	border-radius: 5px;	
	border: none;
	background-color: rgb(52, 59, 72);
}
#btn_cancel:hover {
	background-color: rgb(61, 70, 86);
}
#btn_cancel:pressed {
	background-color: rgb(52, 59, 72);
}
#btn_close {
	border-radius: 5px;	
	border: none;
	background-color: rgb(52, 59, 72);
}
#btn_close:hover {
	background-color: #FF5555;
}
#btn_close:pressed {
	background-color: rgb(52, 59, 72);
}
#content .QLineEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QLineEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QLineEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

#content .QTextEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QTextEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QTextEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

#content .QLabel {
	color: #EAEAF0;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
</string>
