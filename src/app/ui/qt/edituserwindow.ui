   <property name="styleSheet">
    <string notr="true">QWidget{
	color: #F8F8F2;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
/* Bg App */
#bgApp {	
	background-color: #282A36;
}
#contentTopBg {
	background-color: #19181f;
}
#topLogo {
	background-image: url(:/imagem/images/saturn_png.png);
	background-position: centered;
	background-repeat: no-repeat;
}
#titleRightInfo { 
	padding-left: 10px;
	color: #FF5555;
 }
/* Top Buttons */
#rightButtons .QPushButton { background-color: rgba(255, 255, 255, 0); border: none;  border-radius: 5px; }
#rightButtons .QPushButton:hover { background-color: rgb(44, 49, 57); border-style: solid; border-radius: 4px; }
#rightButtons .QPushButton:pressed { background-color: rgb(23, 26, 30); border-style: solid; border-radius: 4px; }
#closeAppBtn{ background-color: rgba(255, 255, 255, 0); border: none;}
#closeAppBtn:hover{ background-color:#ff5555;}
#closeAppBtn:pressed { background-color:rgb(193, 64, 64); border-style: solid;}
/* Bottom Bar */
#bottomBar { background-color: #282A36; }
#bottomBar QLabel { font-size: 10px; color: rgb(113, 126, 149);}
#bottomBar .QProgressBar {
	border-radius: 5px;
	background-color: rgb(52, 59, 72);
	text-align: center;
	color:  rgb(33, 37, 43);
	font-size: 9px;
}
#bottomBar .QProgressBar::chunk {
    background-color: #50FA7B;      
    border-radius: 5px;
}
/*Button */
#btn_saveuser {
	border-radius: 5px;	
	border: none;
	background-color: rgb(66, 209, 102);
}
#btn_saveuser:hover {
	background-color: #50fA7B;
}
#btn_saveuser:pressed {
	background-color: rgb(66, 209, 102);
}
#btn_cancel {
	border-radius: 5px;	
	border: none;
	background-color: rgb(52, 59, 72);
}
#btn_cancel:hover {
	background-color: rgb(61, 70, 86);
}
#btn_cancel:pressed {
	background-color: rgb(52, 59, 72);
}

/*LineEdit */
#content .QLineEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QLineEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QLineEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*TextEdit */
#content .QTextEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QTextEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QTextEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*QLabel */
#content .QLabel {
	color: #EAEAF0;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
</string>
