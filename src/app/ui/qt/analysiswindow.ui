  <widget class="QWidget" name="stylesheet">
   <property name="styleSheet">
    <string notr="true">QWidget{
	color: #F8F8F2;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
#bgApp {	
	background-color: rgb(44, 49, 58);
	border-radius: 10px;
}
#ContentBox {border-radius: 10px;}
#contentTopBg {
	background-color: rgb(33, 37, 43);
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
}
#bottomBar {
	background-color: rgb(33, 37, 43);
	border-bottom-left-radius: 10px;
	border-bottom-right-radius: 10px;
}
#topLogo {
	background-image: url(:/imagem/images/saturn_logo.png);
	background-position: center;
	background-repeat: no-repeat;
}
#titleRightInfo {padding-left: 10px;}

#closeAppBtn{ background-color: rgba(255, 255, 255, 0); border: none;}
#closeAppBtn:hover{ background-color:#ff5555;}
#closeAppBtn:pressed { background-color:rgb(193, 64, 64); border-style: solid;}
#bgAnalysis {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
#bgSample {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
#bgStatus {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
#bgFile {
	background-color: rgb(33, 37, 43);
	border-radius: 10px;
	border: 1px solid #525f7f;
}
/*Button */
#btn_logAnalysis {
	border-radius: 5px;	
	border: none;
	background-color: rgb(66, 209, 102);
}
#btn_logAnalysis::hover {
	background-color: #50fA7B;
}
#btn_logAnalysis::pressed {
	background-color: rgb(66, 209, 102);
}
#btn_cancel {
	border-radius: 5px;	
	border: none;
	background-color: rgb(52, 59, 72);
}
#btn_cancel::hover {
	background-color: rgb(61, 70, 86);
}
#btn_cancel::pressed {
	background-color: rgb(52, 59, 72);
}
#btn_addSample {
	border-radius: 5px;	
	border: none;
	background-color: rgb(52, 59, 72);
}
#btn_addSample::hover {
	background-color: rgb(61, 70, 86);
}
#btn_addSample::pressed {
	background-color: rgb(52, 59, 72);
}

/*LineEdit */
#content .QLineEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QLineEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QLineEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*TextEdit */
#content .QTextEdit {
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	padding-left: 5px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(255, 121, 198);
	color: #ffb86c;
}
#content .QTextEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
#content .QTextEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}

/*QLabel */
#content .QLabel {
	color: #EAEAF0;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}

/*ComboBox */
QComboBox{
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	border: 2px solid rgb(52, 59, 72);
	padding: 5px;
	padding-left: 10px;
	color: #ffb86c;
}
QComboBox:hover{
	border: 2px solid rgb(64, 71, 88);
}
QComboBox::drop-down {
	subcontrol-origin: padding;
	subcontrol-position: top right;
	width: 25px; 
	border-left-width: 3px;
	border-left-color: rgba(39, 44, 54, 150);
	border-left-style: solid;
	border-top-right-radius: 3px;
	border-bottom-right-radius: 3px;	
 }
QComboBox::down-arrow {
	image: url(:/icons/icons/cil-arrow-drop-down.png)
}
QComboBox::down-arrow:on {
    top: 1px;
    left: 1px;
}
QComboBox QAbstractItemView {
	color: #ff5555;	
	background-color: rgb(33, 37, 43);
	padding: 10px;
	selection-background-color: rgb(39, 44, 54);
}
QComboBox QAbstractItemView::indicator {
	width: 15px;
	height: 15px;
}

QComboBox QAbstractItemView::indicator:unchecked {
    border: 1px solid rgb(52, 59, 72);
    background: rgb(44, 49, 60);
}

QComboBox QAbstractItemView::indicator:checked {
	background: 1px solid #50FA7B;
	border: 1px solid rgb(52, 59, 72);	
}
/*CheckBox */
QCheckBox::indicator {
    border: 3px solid rgb(52, 59, 72);
	width: 15px;
	height: 15px;
    background: rgb(44, 49, 60);
}
QCheckBox::indicator:hover {
    border: 3px solid rgb(58, 66, 81);
}
QCheckBox::indicator:checked {
    background: 3px solid rgb(52, 59, 72);
	border: 3px solid rgb(52, 59, 72);	
	background-image: url(:/icons/icons/cil-check-alt.png);
}
QDateEdit{
	background-color: rgb(52, 59, 72);
	border-radius: 5px;
	border: 2px solid rgb(52, 59, 72);
	padding: 5px;
	padding-left: 10px;
	color: #ffb86c;
}
QDateEdit:hover{
	border: 2px solid rgb(64, 71, 88);
}
QDateEdit::drop-down {
	subcontrol-origin: padding;
	subcontrol-position: top right;
	width: 25px; 
	border-left-width: 3px;
	border-left-color: rgba(39, 44, 54, 150);
	border-left-style: solid;
	border-top-right-radius: 3px;
	border-bottom-right-radius: 3px;	
	background-image: url(:/icons/icons/cil-arrow-drop-down.png);
	background-position: center;
	background-repeat: no-reperat;
 }
QDateEdit QAbstractItemView {
	/*color: rgb(255, 121, 198);*/
	color: #ff5555;	
	background-color: rgb(33, 37, 43);
	padding: 10px;
	selection-background-color: rgb(39, 44, 54);
}
QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea &gt; QWidget &gt; QWidget {
    background: transparent;
}
QScrollBar:vertical {
    background: transparent;
    width: 5px;
    margin: 12px 0px 12px 0px;
    border: none;
}
QScrollBar::handle:vertical {
    background: #525f7f;
    min-height: 30px;
    border-radius: 2px;
}
QScrollBar::handle:vertical:hover {
    background: rgb(83, 88, 112);
}
QScrollBar::handle:vertical:pressed {
    background: #343746;
}
QScrollBar::sub-line:vertical {
            height: 14px;
            background: transparent;
            subcontrol-origin: margin;
            subcontrol-position: top;
}
QScrollBar::add-line:vertical {
            height: 14px;
            background: transparent;
            subcontrol-origin: margin;
            subcontrol-position: bottom;
}
QScrollBar::up-arrow:vertical {
            image: url(:/icons/icons/cil-arrow-up.png);
            width: 15px;
            height: 15px;
}
QScrollBar::down-arrow:vertical {
            image: url(:/icons/icons/cil-arrow-down.png);
            width: 15px;
            height: 15px;
        }
QScrollBar::add-page:vertical,
        QScrollBar::sub-page:vertical {
            background: transparent;
        }</string>
