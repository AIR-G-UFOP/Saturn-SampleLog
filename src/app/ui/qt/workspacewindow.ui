   <property name="styleSheet">
    <string notr="true">QWidget{
	color: #EAEAF0;
	font: 8pt &quot;Inter 24pt Medium&quot;;
}
/*Bg App */
#bgApp {	
	background-color: #282A36;
	border-radius: 10px;
}

/*Content App */
#contentBottom {
	background-color: #19181f;
	border-top-left-radius: 10px;
	border-bottom-left-radius: 10px;
}
/* Top Buttons */
#rightButtons .QPushButton { 
	background-color: transparent; 
	border: none;  
}
#rightButtons .QPushButton:hover { 
	background-color: rgb(52, 59, 72);
	border-style: solid; 
}
#rightButtons .QPushButton:pressed { 
	background-color: transparent; 
	border-style: solid; 
}
#closeAppBtn{ 
	background-color: transparent; 
	border-top-right-radius: 10px;
	border: none;
}
#closeAppBtn:hover{ 
	background-color:#ff5555;
}
#closeAppBtn:pressed { 
	background-color:rgb(193, 64, 64); 
	border-style: solid; 
}
#topLogo {
	background-color: transparent;
	background-image: url(:/imagem/images/saturn_logo.png);
	background-position: center;
	background-repeat: no-repeat;
}
#titleLeftApp { 
	font: 10pt &quot;Inter 24pt Medium&quot;; 
}
#titleRightInfo { 
	padding-left: 10px; 
	font: 8pt &quot;Inter 24pt Medium&quot;; 
}
/* MENUS */
#topMenu .QPushButton {	
	border: none;
	background-color: transparent;
	text-align: left;
	border-left: 18px solid transparent;
}
#topMenu .QPushButton:hover {
	background-color: rgb(52, 59, 72); 
}
#topMenu .QPushButton:pressed {	
	background-color: #ff5555;
	color: rgb(255, 255, 255);
}
#bottomMenu .QPushButton {	
	border: none;
	background-color:transparent;
	text-align: left;
	border-left: 18px solid transparent;
}
#bottomMenu .QPushButton:hover {
	background-color: rgb(44, 49, 57); 
}
#bottomMenu .QPushButton:pressed {	
	background-color: #ff5555;
	color: rgb(255, 255, 255);
}
/* Toggle Button */
#toggleButton {
	border: none;
	text-align: left;
	border-left: 18px solid transparent;
	color: #A8ABB3;
}
#toggleButton:hover {
	background-color: rgb(52, 59, 72); 
}
#toggleButton:pressed {
	background-color: #ff5555;
}
#bottomBar { 
	background-color: transparent; 
}
#bottomBar QLabel { 
	font-size: 11px; 
	color: rgb(113, 126, 149); 
	padding-left: 10px; 
	padding-right: 10px; 
	padding-bottom: 2px; }
#panelArea {
	background-color: transparent;
	border: none;
}
QScrollBar:vertical {
    background: transparent;
    width: 5px;
    margin: 12px 0px 12px 0px;
    border: none;
}
QScrollBar::handle:vertical {
    background: rgb(83, 88, 112);
    min-height: 30px;
    border-radius: 2px;
}
QScrollBar::handle:vertical:hover {
    background: rgb(83, 88, 112);
}
QScrollBar::handle:vertical:pressed {
    background: rgb(83, 88, 112);
}
QScrollBar::sub-line:vertical {
            height: 14px;
            background: transparent;
            subcontrol-origin: margin;
            subcontrol-position: top;
}
QScrollBar::add-line:vertical {
            height: 14px;
            background: transparent;
            subcontrol-origin: margin;
            subcontrol-position: bottom;
}
QScrollBar::up-arrow:vertical {
            image: url(:/icons/icons/cil-arrow-up.png);
            width: 15px;
            height: 15px;
}
QScrollBar::down-arrow:vertical {
            image: url(:/icons/icons/cil-arrow-down.png);
            width: 15px;
            height: 15px;
}
QScrollBar::add-page:vertical,
        QScrollBar::sub-page:vertical {
            background: transparent;
}
QScrollBar:horizontal {
    background: transparent;
    height: 5px;
    margin: 0px 12px 0px 12px;
    border: none;
}
QScrollBar::handle:horizontal {
    background: rgb(83, 88, 112);
    min-width: 30px;
    border-radius: 2px;
}
QScrollBar::sub-line:horizontal,
QScrollBar::add-line:horizontal {
    width: 14px;
    background: transparent;
}
QScrollBar::handle:horizontal:hover {
    background: rgb(83, 88, 112);
}
QScrollBar::handle:horizontal:pressed {
    background: rgb(83, 88, 112);
}
QScrollBar::right-arrow:horizontal {
            image: url(:/icons/icons/cil-arrow-right.png);
            width: 10px;
            height: 10px;
}
QScrollBar::left-arrow:horizontal {
            image: url(:/icons/icons/cil-arrow-left.png);
            width: 10px;
            height: 10px;
}
QScrollBar::add-page:horizontal,
        QScrollBar::sub-page:horizontal {
            background: transparent;
        }

QContentStack &gt; QWidget &gt; QWidget {
	background-color: transparent;
}
#scrollAreaWidgetContents {
	background-color: transparent;
}
QScrollArea {
    background: transparent;
    border: none;
}
QScrollArea &gt; QWidget &gt; QWidget {
    background: transparent;
}
